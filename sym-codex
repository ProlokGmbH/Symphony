#!/usr/bin/env bash

_sym_codex_sourced=0
if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
  _sym_codex_sourced=1
fi

sym_codex_finish() {
  local status="${1:-0}"

  if (( _sym_codex_sourced )); then
    return "$status"
  fi

  exit "$status"
}

sym_codex_stderr() {
  printf 'sym-codex: %s\n' "$*" >&2
}

sym_codex_usage() {
  cat >&2 <<'EOF'
Usage:
  sym-codex [<issue.identifier>]
  sym-codex --observer [<issue.identifier>]

Direct execution runs Codex in the selected worktree.
If no issue identifier is given from inside a configured worktree, sym-codex reuses that worktree.
If the script is sourced, the current shell stays in that worktree afterwards.
EOF
}

SYM_CODEX_PROMPT=""
SYM_CODEX_WORKFLOW_STEP=""

sym_codex_die() {
  sym_codex_stderr "$@"
  sym_codex_finish 1
}

sym_codex_activate_venv() {
  local project_root="$1"
  local workspace="$2"
  local source_repo="$3"
  local candidate_root=""
  local activate_script=""

  for candidate_root in "$project_root" "$workspace" "$source_repo"; do
    if [[ -n "$candidate_root" ]]; then
      activate_script="$candidate_root/.venv/bin/activate"

      if [[ -f "$activate_script" ]]; then
        export BASH_ENV="$activate_script"
        export VIRTUAL_ENV_DISABLE_PROMPT=1
        # shellcheck disable=SC1090
        . "$activate_script"
        return 0
      fi
    fi
  done

  return 0
}

sym_codex_realpath() {
  local raw_path="$1"
  local resolved_path=""

  if command -v readlink >/dev/null 2>&1; then
    resolved_path="$(readlink -f -- "$raw_path" 2>/dev/null || true)"
  fi

  if [[ -z "$resolved_path" ]] && command -v realpath >/dev/null 2>&1; then
    resolved_path="$(realpath "$raw_path" 2>/dev/null || true)"
  fi

  if [[ -n "$resolved_path" ]]; then
    printf '%s\n' "$resolved_path"
    return 0
  fi

  return 1
}

sym_codex_source_repo() {
  local script_source="${BASH_SOURCE[0]}"
  local resolved_source
  local script_dir
  local common_dir

  if [[ "$script_source" != */* ]]; then
    resolved_source="$(command -v -- "$script_source" 2>/dev/null || true)"

    if [[ -n "$resolved_source" ]]; then
      script_source="$resolved_source"
    fi
  fi

  resolved_source="$(sym_codex_realpath "$script_source" 2>/dev/null || true)"

  if [[ -n "$resolved_source" ]]; then
    script_source="$resolved_source"
  fi

  script_dir="$(cd "$(dirname "$script_source")" && pwd -P 2>/dev/null)" ||
    sym_codex_die "cannot resolve script directory"

  if [[ -f "$script_dir/WORKFLOW.md" && -f "$script_dir/mix.exs" ]]; then
    printf '%s\n' "$script_dir"
    return
  fi

  common_dir="$(git -C "$script_dir" rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true)"

  if [[ -n "$common_dir" ]]; then
    (
      cd "$common_dir/.." >/dev/null 2>&1 && pwd -P
    )
    return
  fi

  sym_codex_die "cannot determine the Symphony source repository"
}

sym_codex_run_mix() {
  local source_repo="$1"
  local config_file="$source_repo/mise.toml"
  local common_dir=""
  local shared_repo=""
  shift

  if [[ -z "${MIX_DEPS_PATH:-}" ]]; then
    common_dir="$(git -C "$source_repo" rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true)"

    if [[ -n "$common_dir" ]]; then
      shared_repo="$(
        cd "$common_dir/.." >/dev/null 2>&1 && pwd -P
      )" || shared_repo=""

      if [[ -n "$shared_repo" && -d "$shared_repo/deps" ]]; then
        export MIX_DEPS_PATH="$shared_repo/deps"
      fi

      if [[ -n "$shared_repo" && -z "${MIX_BUILD_ROOT:-}" && -d "$shared_repo/_build" ]]; then
        export MIX_BUILD_ROOT="$shared_repo/_build"
      fi
    fi
  fi

  if command -v mise >/dev/null 2>&1; then
    if [[ -f "$config_file" ]]; then
      mise trust -q -y "$config_file" >/dev/null
    fi

    mise exec -- mix "$@"
  else
    mix "$@"
  fi
}

sym_codex_prepare_mix() {
  local source_repo="$1"

  sym_codex_run_mix "$source_repo" compile 1>&2
}

sym_codex_project_root() {
  local start_dir="$1"
  local common_dir
  local project_root

  common_dir="$(git -C "$start_dir" rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true)"

  if [[ -n "$common_dir" ]]; then
    project_root="$(
      cd "$common_dir/.." >/dev/null 2>&1 && pwd -P
    )" || return 1

    printf '%s\n' "$project_root"
    return 0
  fi

  project_root="$(git -C "$start_dir" rev-parse --path-format=absolute --show-toplevel 2>/dev/null || true)"

  if [[ -n "$project_root" ]]; then
    printf '%s\n' "$project_root"
    return 0
  fi

  (
    cd "$start_dir" >/dev/null 2>&1 && pwd -P
  )
}

sym_codex_workspace_root() {
  local source_repo="$1"
  local workflow_file="$2"
  local project_root="$3"

  if [[ -n "${SYMPHONY_PROJECT_WORKTREES_ROOT:-}" ]]; then
    printf '%s\n' "$SYMPHONY_PROJECT_WORKTREES_ROOT"
    return
  fi

  (
    cd "$source_repo" || exit 1
    export SYMPHONY_PROJECT_ROOT="$project_root"
    export SYMPHONY_PROJECT_WORKTREES_ROOT="${project_root}-worktrees"
    sym_codex_prepare_mix "$source_repo"
    sym_codex_run_mix "$source_repo" run --no-compile --no-start -e '
      workflow_path = Enum.at(System.argv(), 0) || raise "missing workflow file"
      env_files_dir = System.get_env("SYMPHONY_PROJECT_ROOT") || File.cwd!()

      case SymphonyElixir.Codex.ScriptSupport.workspace_root(workflow_path, env_files_dir) do
        {:ok, workspace_root} ->
          IO.write(workspace_root)

        {:error, reason} ->
          raise "workspace_root_error: #{inspect(reason)}"
      end
    ' -- "$workflow_file"
  )
}

sym_codex_build_manual_prompt() {
  local source_repo="$1"
  local workflow_file="$2"
  local interactive_workflow_file="$3"
  local project_root="$4"
  local issue_identifier="$5"
  local workspace="$6"

  (
    cd "$source_repo" || exit 1
    export SYMPHONY_ACTIVE_REPO_ROOT="$workspace"
    export SYMPHONY_PROJECT_ROOT="$project_root"
    export SYMPHONY_PROJECT_WORKTREES_ROOT="${project_root}-worktrees"
    export SYMPHONY_SOURCE_REPO="$source_repo"
    export SYMPHONY_WORKFLOW_FILE="$workflow_file"
    export SYMPHONY_WORKFLOW_DIR
    SYMPHONY_WORKFLOW_DIR="$(cd "$(dirname "$workflow_file")" >/dev/null 2>&1 && pwd -P)"
    sym_codex_prepare_mix "$source_repo"
    sym_codex_run_mix "$source_repo" run --no-compile --no-start -e '
      workflow_path = Enum.at(System.argv(), 0) || raise "missing workflow file"
      interactive_workflow_path = Enum.at(System.argv(), 1) || raise "missing interactive workflow file"
      issue_identifier = Enum.at(System.argv(), 2) || raise "missing issue identifier"
      env_files_dir = System.get_env("SYMPHONY_PROJECT_ROOT") || File.cwd!()

      case SymphonyElixir.Codex.ScriptSupport.manual_prompt_context(
             workflow_path,
             interactive_workflow_path,
             issue_identifier,
             env_files_dir
           ) do
        {:ok, %{prompt: prompt, workflow_step: workflow_step}} ->
          IO.write("SYM_CODEX_CONTEXT_V1\n")
          IO.write((workflow_step || "") <> "\n")
          IO.write("SYM_CODEX_PROMPT_V1\n")
          IO.write(prompt)

        {:error, reason} ->
          raise "manual_prompt_error: #{inspect(reason)}"
      end
    ' -- "$workflow_file" "$interactive_workflow_file" "$issue_identifier"
  )
}

sym_codex_parse_manual_prompt_context() {
  local prompt_context="$1"
  local context_prefix=$'SYM_CODEX_CONTEXT_V1\n'
  local prompt_marker=$'\nSYM_CODEX_PROMPT_V1\n'
  local remainder=""

  if [[ "$prompt_context" == "$context_prefix"* ]] && [[ "$prompt_context" == *"$prompt_marker"* ]]; then
    remainder="${prompt_context#"$context_prefix"}"
    SYM_CODEX_WORKFLOW_STEP="${remainder%%"$prompt_marker"*}"
    SYM_CODEX_PROMPT="${remainder#*"$prompt_marker"}"
    return 0
  fi

  SYM_CODEX_WORKFLOW_STEP=""
  SYM_CODEX_PROMPT="$prompt_context"
}

sym_codex_set_launch_profile() {
  local workflow_step="$1"

  SYM_CODEX_MODEL="gpt-5.5"
  SYM_CODEX_REASONING_EFFORT="high"

  case "$workflow_step" in
    "Review (AI)")
      SYM_CODEX_REASONING_EFFORT="high"
      ;;
  esac
}

sym_codex_expand_path() {
  local project_root="$1"
  local raw_path="$2"

  case "$raw_path" in
    "~")
      printf '%s\n' "$HOME"
      ;;
    "~/"*)
      printf '%s\n' "$HOME/${raw_path#~/}"
      ;;
    /*)
      printf '%s\n' "$raw_path"
      ;;
    *)
      printf '%s\n' "$project_root/$raw_path"
      ;;
  esac
}

sym_codex_safe_identifier() {
  LC_ALL=C sed 's/[^A-Za-z0-9._-]/_/g' <<<"$1"
}

sym_codex_toml_basic_string() {
  local value="$1"

  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\t'/\\t}"

  printf '"%s"' "$value"
}

sym_codex_infer_issue_identifier_from_cwd() {
  local source_repo="$1"
  local workflow_file="$2"
  local project_root="$3"
  local workspace_root
  local current_dir
  local relative_path
  local issue_identifier

  workspace_root="$(sym_codex_workspace_root "$source_repo" "$workflow_file" "$project_root")" || return 1
  workspace_root="$(sym_codex_expand_path "$project_root" "$workspace_root")"
  current_dir="$(pwd -P)"

  case "$current_dir" in
    "$workspace_root"/*)
      relative_path="${current_dir#"$workspace_root"/}"
      issue_identifier="${relative_path%%/*}"

      if [[ -n "$issue_identifier" ]]; then
        printf '%s\n' "$issue_identifier"
        return 0
      fi
      ;;
  esac

  return 1
}

sym_codex_current_workspace_for_issue() {
  local issue_identifier="$1"
  local expected_branch="symphony/$issue_identifier"
  local current_dir
  local branch_name
  local workspace_root

  current_dir="$(pwd -P)"

  if ! git -C "$current_dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    return 1
  fi

  branch_name="$(git -C "$current_dir" branch --show-current 2>/dev/null || true)"

  if [[ "$branch_name" != "$expected_branch" ]]; then
    return 1
  fi

  workspace_root="$(git -C "$current_dir" rev-parse --path-format=absolute --show-toplevel 2>/dev/null || true)"

  if [[ -z "$workspace_root" ]]; then
    return 1
  fi

  printf '%s\n' "$workspace_root"
}

sym_codex_infer_issue_identifier_from_branch() {
  local current_dir
  local branch_name
  local issue_identifier

  current_dir="$(pwd -P)"

  if ! git -C "$current_dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    return 1
  fi

  branch_name="$(git -C "$current_dir" branch --show-current 2>/dev/null || true)"

  case "$branch_name" in
    symphony/*)
      issue_identifier="${branch_name#symphony/}"

      if [[ -n "$issue_identifier" ]]; then
        printf '%s\n' "$issue_identifier"
        return 0
      fi
      ;;
  esac

  return 1
}

sym_codex_resolve_workspace() {
  local source_repo="$1"
  local workflow_file="$2"
  local project_root="$3"
  local issue_identifier="$4"
  local workspace_root
  local safe_identifier
  local workspace
  local branch_name
  local expected_branch="symphony/$issue_identifier"

  workspace_root="$(sym_codex_workspace_root "$source_repo" "$workflow_file" "$project_root")" ||
    sym_codex_die "cannot resolve workspace root from $workflow_file"
  workspace_root="$(sym_codex_expand_path "$project_root" "$workspace_root")"

  safe_identifier="$(sym_codex_safe_identifier "$issue_identifier")"
  workspace="$workspace_root/$safe_identifier"

  if ! git -C "$workspace" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    sym_codex_die "no existing worktree for $issue_identifier at $workspace"
  fi

  branch_name="$(git -C "$workspace" branch --show-current 2>/dev/null || true)"

  if [[ "$branch_name" != "$expected_branch" ]]; then
    sym_codex_die "worktree $workspace is on branch ${branch_name:-<unknown>}, expected $expected_branch"
  fi

  printf '%s\n' "$workspace"
}

sym_codex_run() {
  local observer_mode=0
  local issue_identifier_inferred=0
  local issue_identifier=""
  local source_repo
  local project_root
  local workflow_file
  local interactive_workflow_file
  local workspace=""
  local prompt_context=""
  local prompt=""
  local workflow_step=""
  local -a codex_args=(--config shell_environment_policy.inherit=all)

  while (($# > 0)); do
    case "$1" in
      --observer|--app-server|--ubserver)
        observer_mode=1
        ;;
      -h|--help)
        sym_codex_usage
        sym_codex_finish 0
        ;;
      --)
        shift
        break
        ;;
      -*)
        sym_codex_die "unknown option: $1"
        ;;
      *)
        if [[ -n "$issue_identifier" ]]; then
          sym_codex_die "expected at most one issue identifier"
        fi

        issue_identifier="$1"
        ;;
    esac

    shift
  done

  if (($# > 0)); then
    sym_codex_die "unexpected positional arguments: $*"
  fi

  if ! source_repo="$(sym_codex_source_repo)"; then
    sym_codex_finish 1
  fi

  if ! project_root="$(sym_codex_project_root "$(pwd -P)")"; then
    sym_codex_die "cannot determine the local project root"
  fi

  workflow_file="${SYMPHONY_WORKFLOW_FILE:-$source_repo/WORKFLOW.md}"
  interactive_workflow_file="${SYMPHONY_WORKFLOW_INTERACTIVE_FILE:-$source_repo/WORKFLOW_INTERACTIVE.md}"

  if [[ -z "$issue_identifier" ]]; then
    issue_identifier="$(sym_codex_infer_issue_identifier_from_branch 2>/dev/null || true)"

    if [[ -n "$issue_identifier" ]]; then
      issue_identifier_inferred=1
    else
      issue_identifier="$(sym_codex_infer_issue_identifier_from_cwd "$source_repo" "$workflow_file" "$project_root" 2>/dev/null || true)"

      if [[ -n "$issue_identifier" ]]; then
        issue_identifier_inferred=1
      fi
    fi
  fi

  if [[ -n "$issue_identifier" ]]; then
    if (( issue_identifier_inferred )); then
      workspace="$(sym_codex_current_workspace_for_issue "$issue_identifier" 2>/dev/null || true)"
    fi

    if [[ -z "$workspace" ]] &&
         ! workspace="$(sym_codex_resolve_workspace "$source_repo" "$workflow_file" "$project_root" "$issue_identifier")"; then
      sym_codex_finish 1
    fi

    if (( ! issue_identifier_inferred )); then
      cd "$workspace" || sym_codex_die "cannot change into $workspace"
    fi
  elif (( ! observer_mode )); then
    sym_codex_usage
    sym_codex_finish 1
  fi

  if (( ! observer_mode )); then
    prompt_context="$(sym_codex_build_manual_prompt "$source_repo" "$workflow_file" "$interactive_workflow_file" "$project_root" "$issue_identifier" "$workspace")" ||
      sym_codex_die "cannot build prompt for $issue_identifier"
    sym_codex_parse_manual_prompt_context "$prompt_context"
    prompt="$SYM_CODEX_PROMPT"
    workflow_step="$SYM_CODEX_WORKFLOW_STEP"
  fi

  sym_codex_set_launch_profile "$workflow_step"
  codex_args+=(
    --config "model_reasoning_effort=$SYM_CODEX_REASONING_EFFORT"
    --model "$SYM_CODEX_MODEL"
  )

  if (( observer_mode )); then
    codex_args+=(app-server)
  else
    codex_args+=(
      --config "mcp_servers.symphony_linear.command=$(sym_codex_toml_basic_string "$source_repo/sym-codex-mcp")"
      --config "mcp_servers.symphony_linear.env={SYMPHONY_SOURCE_REPO=$(sym_codex_toml_basic_string "$source_repo"),SYMPHONY_WORKFLOW_FILE=$(sym_codex_toml_basic_string "$workflow_file")}"
      "$prompt"
    )
  fi

  if (( _sym_codex_sourced )); then
    sym_codex_activate_venv "$project_root" "$workspace" "$source_repo"
    codex "${codex_args[@]}"
    return $?
  fi

  sym_codex_activate_venv "$project_root" "$workspace" "$source_repo"
  exec codex "${codex_args[@]}"
}

sym_codex_run "$@"
