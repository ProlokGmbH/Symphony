#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f -- "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"
SKILLS_DIR="$SCRIPT_DIR/.codex/skills"
USER_SKILLS_DIR="$HOME/.codex/skills"
PROJECT_DIR="$SCRIPT_DIR"

mkdir -p "$USER_SKILLS_DIR"

shopt -s nullglob
for skill_dir in "$SKILLS_DIR"/symphony-* "$SKILLS_DIR"/review "$SKILLS_DIR"/test; do
  if [ ! -d "$skill_dir" ]; then
    continue
  fi

  skill_name="$(basename -- "$skill_dir")"
  target_path="$USER_SKILLS_DIR/$skill_name"

  if [ -e "$target_path" ] && [ ! -L "$target_path" ]; then
    echo "symphony: $target_path exists and is not a symlink" >&2
    exit 1
  fi

  ln -sfnT "$skill_dir" "$target_path"
done

for user_skill in "$USER_SKILLS_DIR"/symphony-* "$USER_SKILLS_DIR"/review "$USER_SKILLS_DIR"/test; do
  if [ ! -L "$user_skill" ]; then
    continue
  fi

  skill_name="$(basename -- "$user_skill")"
  if [ ! -d "$SKILLS_DIR/$skill_name" ]; then
    unlink "$user_skill"
  fi
done
shopt -u nullglob

if ! command -v mise >/dev/null 2>&1; then
  echo "symphony: mise not found in PATH" >&2
  exit 127
fi

eval "$(mise env -C "$PROJECT_DIR" -s bash)"
exec "$PROJECT_DIR/bin/symphony" "$@"
