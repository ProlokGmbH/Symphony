#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f -- "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"
SKILLS_DIR="$SCRIPT_DIR/.codex/skills"
USER_SKILLS_DIR="$HOME/.codex/skills"
USER_BIN_DIR="$HOME/.local/bin"
PROJECT_DIR="$SCRIPT_DIR"
CODEX_LINK_PATH="$USER_BIN_DIR/sym-codex"
CODEX_TARGET_PATH="$PROJECT_DIR/sym-codex"
LEGACY_CODEX_LINK_PATH="$USER_BIN_DIR/symphony-codex"

mkdir -p "$USER_SKILLS_DIR"
mkdir -p "$USER_BIN_DIR"

if [ -e "$CODEX_LINK_PATH" ] && [ ! -L "$CODEX_LINK_PATH" ]; then
  echo "symphony: $CODEX_LINK_PATH exists and is not a symlink" >&2
  exit 1
fi

ln -sfnT "$CODEX_TARGET_PATH" "$CODEX_LINK_PATH"

shopt -s nullglob
if [ -L "$LEGACY_CODEX_LINK_PATH" ]; then
  unlink "$LEGACY_CODEX_LINK_PATH"
fi

for skill_dir in "$SKILLS_DIR"/symphony-* "$SKILLS_DIR"/sym-review "$SKILLS_DIR"/sym-test; do
  if [ ! -d "$skill_dir" ]; then
    continue
  fi

  skill_name="$(basename -- "$skill_dir")"
  target_path="$USER_SKILLS_DIR/$skill_name"

  if [ -e "$target_path" ] && [ ! -L "$target_path" ]; then
    echo "symphony: $target_path exists and is not a symlink" >&2
    exit 1
  fi

  ln -sfnT "$skill_dir" "$target_path"
done

for user_skill in "$USER_SKILLS_DIR"/symphony-* "$USER_SKILLS_DIR"/sym-review "$USER_SKILLS_DIR"/sym-test "$USER_SKILLS_DIR"/review "$USER_SKILLS_DIR"/test; do
  if [ ! -L "$user_skill" ]; then
    continue
  fi

  skill_name="$(basename -- "$user_skill")"
  if [ ! -d "$SKILLS_DIR/$skill_name" ]; then
    unlink "$user_skill"
  fi
done
shopt -u nullglob

if ! command -v mise >/dev/null 2>&1; then
  echo "symphony: mise not found in PATH" >&2
  exit 127
fi

eval "$(mise env -C "$PROJECT_DIR" -s bash)"
exec "$PROJECT_DIR/bin/symphony" "$@"
