# Shared Symphony defaults for this repo.
#
# Load order:
# 1. existing process environment
# 2. this .env file
# 3. .env.local
#
# Keep only non-secret shared defaults here.
# Local machine-specific overrides belong in .env.local.
#
# Required for the default WORKFLOW.md:
# - LINEAR_API_KEY: Linear personal API key
# - LINEAR_PROJECT_SLUG: Linear project slug from the project URL
# - LINEAR_ASSIGNEE: Linear user email for the assigned engineer
#
# Symphony provides these path variables automatically at runtime.
# Do not set them manually in .env:
# - SYMPHONY_PROJECT_ROOT
# - SYMPHONY_PROJECT_WORKTREES_ROOT
# - SYMPHONY_WORKFLOW_DIR
# - SYMPHONY_WORKFLOW_FILE

LINEAR_API_KEY="lin_api_replace_me"
LINEAR_PROJECT_SLUG="your-linear-project-slug"
LINEAR_ASSIGNEE="dev@example.com"
